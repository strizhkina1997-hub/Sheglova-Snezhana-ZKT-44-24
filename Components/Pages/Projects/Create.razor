@page "/projects/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrator")]
@using Microsoft.EntityFrameworkCore
@using JiraMinimal.Data
@rendermode InteractiveServer
@inject IDbContextFactory<JiraContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Добавление проекта</PageTitle>
<h1>Добавление проекта</h1>

<EditForm Model="project" OnValidSubmit="CreateProject" FormName="createProject">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="mb-3">
        <label class="form-label">Название:</label>
        <InputText @bind-Value="project.Name" class="form-control" />
        <ValidationMessage For="() => project.Name" />
    </div>
    <div class="mb-3">
        <label class="form-label">Описание:</label>
        <InputTextArea @bind-Value="project.Description" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Отдел:</label>
        <InputSelect @bind-Value="project.DepartmentId" class="form-control">
            @foreach (var dep in departments)
            {
                <option value="@dep.DepartmentId">@dep.Name</option>
            }
        </InputSelect>
    </div>
    <div class="mb-3">
        <label class="form-label">Владелец:</label>
        <InputSelect @bind-Value="project.OwnerId" class="form-control">
            @foreach (var user in users)
            {
                <option value="@user.Id">@user.FullName (@user.Email)</option>
            }
        </InputSelect>
    </div>
    <button type="submit" class="btn btn-primary">Создать проект</button>
</EditForm>
<a href="/projects">Назад к списку</a>

@code {
    private Project project = new() { CreatedAt = DateTime.Now };
    private List<Department> departments = new();
    private List<ApplicationUser> users = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        departments = await context.Departments.ToListAsync();
        users = await context.Users.ToListAsync();

        // Предустанавливаем первый отдел и первого пользователя, чтобы избежать ошибок валидации
        if (departments.Any() && project.DepartmentId == 0)
            project.DepartmentId = departments.First().DepartmentId;
        if (users.Any() && string.IsNullOrEmpty(project.OwnerId))
            project.OwnerId = users.First().Id;
    }

    private async Task CreateProject()
    {
        using var context = DbFactory.CreateDbContext();
        context.Projects.Add(project);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/projects");
    }
}