@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="#">Jira Minimal</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <!-- Главная -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Главная
            </NavLink>
        </div>

        <!-- Отделы -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/departments">
                <span class="bi bi-building-nav-menu" aria-hidden="true"></span> Отделы
            </NavLink>
        </div>

        <!-- Проекты -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/projects">
                <span class="bi bi-kanban-nav-menu" aria-hidden="true"></span> Проекты
            </NavLink>
        </div>

        <!-- Задачи -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/issues">
                <span class="bi bi-list-task-nav-menu" aria-hidden="true"></span> Задачи
            </NavLink>
        </div>

        <!-- Уведомления -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/notifications">
                <span class="bi bi-bell-nav-menu" aria-hidden="true"></span> Уведомления
            </NavLink>
        </div>

        <!-- Пользователи (только для администратора) -->
        <AuthorizeView Roles="Administrator">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/users">
                    <span class="bi bi-people-nav-menu" aria-hidden="true"></span> Пользователи
                </NavLink>
            </div>
        </AuthorizeView>

        <!-- Экспорт / Импорт -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/exportimport">
                <span class="bi bi-file-earmark-spreadsheet-nav-menu" aria-hidden="true"></span> Excel
            </NavLink>
        </div>

        <!-- Визуализация (Plotly) -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/charts">
                <span class="bi bi-bar-chart-nav-menu" aria-hidden="true"></span> Графики
            </NavLink>
        </div>

        <!-- Файлы (вложения) -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/files">
                <span class="bi bi-paperclip-nav-menu" aria-hidden="true"></span> Файлы
            </NavLink>
        </div>

        <!-- Блок авторизации (стандартный) -->
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Выйти
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Регистрация
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Авторизация
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
    }

    public void Dispose()
    {
        // Nothing to dispose
    }
}